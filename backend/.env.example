# Database configuration
DATABASE_URL=sqlite:///./cpee_dashboard.db

# Meta API
META_ACCESS_TOKEN=your_access_token_here
META_AD_ACCOUNT_IDS=act_1234567890,act_0987654321

# Collection mode (real or mock)
MODO_COLETA=real

# API Configuration
API_PORT=8000
REFRESH_INTERVAL=1800

# CORS Configuration
CORS_ORIGIN=https://your-frontend-domain.com

# Export API Key (for secure exports)
EXPORT_API_KEY=your_secure_api_key_here
